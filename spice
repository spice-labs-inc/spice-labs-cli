#!/usr/bin/env bash
set -euo pipefail

# ── Log file tee (must be first) ─────────────────────────────────────────────

LOG_FILE=""
for arg in "$@"; do
  [[ "$arg" == --log-file=* ]] && LOG_FILE="${arg#--log-file=}" && break
done
if [ -z "$LOG_FILE" ]; then
  prev=""
  for arg in "$@"; do
    [[ "$prev" == "--log-file" ]] && LOG_FILE="$arg" && break
    prev="$arg"
  done
fi
if [ -n "$LOG_FILE" ]; then
  exec > >(tee >(sed -u 's/\x1b\[[0-9;]*[a-zA-Z]//g' >>"$LOG_FILE"))
  exec 2>&1
fi

# ── Script update check ─────────────────────────────────────────────────────

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v sha256sum &>/dev/null; then
  LOCAL_HASH=$(sha256sum "$SCRIPT_PATH" | awk '{print $1}')
else
  LOCAL_HASH=$(shasum -a 256 "$SCRIPT_PATH" | awk '{print $1}')
fi

if [ "${SPICE_LABS_CLI_SKIP_PULL:-0}" != "1" ]; then
  REMOTE_HASH=$(
    curl -fsSL https://api.github.com/repos/spice-labs-inc/spice-labs-cli/releases/latest 2>/dev/null |
      awk '
        BEGIN { found_spice = 0 }
        /"name":[[:space:]]*"spice"/ { found_spice = 1 }
        found_spice && /"digest":[[:space:]]*"sha256:/ {
          gsub(/.*"digest":[[:space:]]*"sha256:/, "")
          gsub(/".*/, "")
          print
          exit(0)
        }'
  ) || true

  if [[ -n "$REMOTE_HASH" && "$LOCAL_HASH" != "$REMOTE_HASH" ]]; then
    echo "⚠️  A newer version of this script is available. Run:"
    echo "    curl -sSfL https://install.spicelabs.io | bash"
  fi
fi

# ── Helpers ──────────────────────────────────────────────────────────────────

abs_path() {
  local path="$1"
  [[ "$path" == ~* ]] && path="${path/#\~/$HOME}"
  if [ ! -e "$path" ]; then
    echo "ERROR ❌ Input path does not exist: $path" >&2
    echo "INFO  Use --help for usage information." >&2
    exit 2
  fi
  if [ -d "$path" ]; then
    (cd "$path" && pwd)
  else
    (cd "$(dirname "$path")" && echo "$(pwd)/$(basename "$path")")
  fi
}

# Known subcommand tokens (not paths)
is_subcommand() {
  case "$1" in
    survey|inventory|static|runtime|pass|decode) return 0 ;;
    registry|discover|run|status|list|retry) return 0 ;;
    *) return 1 ;;
  esac
}

# Flags that consume the next arg as a value
is_value_flag() {
  case "$1" in
  --output | --threads | --max-records | --chunk-size | --log-level | --log-file | --tag-json | --goat-rodeo-args | --ginger-args | --features | --config | --discovery) return 0 ;;
  *) return 1 ;;
  esac
}

SPICE_LABS_CLI_JAR="${SPICE_LABS_CLI_JAR:-/opt/spice-labs-cli/spice-labs-cli.jar}"
IMAGE="${SPICE_IMAGE:-spicelabs/spice-labs-cli}"
TAG="${SPICE_IMAGE_TAG:-latest}"
# If SPICE_IMAGE is set, use it verbatim (no tag appended). Otherwise build
# the ref from the resolved IMAGE and TAG.
if [ -n "${SPICE_IMAGE:-}" ]; then
  IMAGE_REF="${SPICE_IMAGE}"
else
  IMAGE_REF="${IMAGE}:${TAG}"
fi

# ── Feature flag parsing (must happen before Docker checks / image pull) ──────
#
# --features enterprise  → enterprise image (allspice + sassafras)
# --features federal      → federal image (enterprise + report_cli + rogues gallery)
# Strip the flag so it is not forwarded to the CLI container.

FEATURES=""
PARSED_ARGS=()
prev_arg=""
for arg in "$@"; do
  if [[ "$arg" == --features=* ]]; then
    FEATURES="${arg#--features=}"
    continue
  elif [[ "$prev_arg" == --features ]]; then
    FEATURES="$arg"
    prev_arg=""
    continue
  elif [[ "$arg" == --features ]]; then
    prev_arg="$arg"
    continue
  fi
  PARSED_ARGS+=("$arg")
done
# Flush any orphaned --features value (malformed input)
[ -n "$prev_arg" ] && FEATURES="$prev_arg" && prev_arg=""

if [ -z "${SPICE_IMAGE:-}" ]; then
  case "${FEATURES}" in
  enterprise)
    IMAGE_REF="ghcr.io/spice-labs-inc/spice-labs-cli-enterprise:latest"
    ;;
  federal)
    IMAGE_REF="ghcr.io/spice-labs-inc/spice-labs-cli-federal:latest"
    ;;
  esac
fi

# Replace "$@" with the stripped args for the rest of the script.
set -- "${PARSED_ARGS[@]}"

# ── JVM mode (no Docker, no path rewriting) ──────────────────────────────────

if [ "${SPICE_LABS_CLI_USE_JVM:-0}" = "1" ]; then
  [ -f "$SPICE_LABS_CLI_JAR" ] || {
    echo "Missing: $SPICE_LABS_CLI_JAR"
    exit 1
  }
  JVM_ARGS="${SPICE_LABS_JVM_ARGS:--XX:MaxRAMPercentage=75}"
  # Strip --log-file (handled at shell level)
  FILTERED=()
  prev=""
  for arg in "$@"; do
    if [[ "$arg" == --log-file=* ]]; then
      continue
    elif [[ "$prev" == "--log-file" ]]; then
      prev=""
      continue
    elif [[ "$arg" == "--log-file" ]]; then
      prev="$arg"
      continue
    else
      FILTERED+=("$arg")
      prev=""
    fi
  done
  # Plugins (e.g. the `registry` command) ride beside the jar in plugins/; add them to
  # the classpath. -cp (not -jar) requires naming the main class explicitly.
  PLUGINS_DIR="$(dirname "$SPICE_LABS_CLI_JAR")/plugins"
  CP="$SPICE_LABS_CLI_JAR"
  [ -d "$PLUGINS_DIR" ] && CP="${SPICE_LABS_CLI_JAR}:${PLUGINS_DIR}/*"
  # shellcheck disable=SC2086
  exec java $JVM_ARGS -cp "$CP" io.spicelabs.cli.SpiceLabsCLI ${FILTERED[@]+"${FILTERED[@]}"}
fi

# ── Docker checks ────────────────────────────────────────────────────────────

if ! command -v docker &>/dev/null; then
  echo "❌ Docker is not installed or not in PATH"
  echo "   Please install Docker: https://docs.docker.com/get-docker/"
  exit 1
fi

DEBUG_MODE=0
for arg in "$@"; do
  arg_lower=$(echo "$arg" | tr '[:upper:]' '[:lower:]')
  [[ "$arg_lower" == --log-level=debug || "$arg_lower" == --log-level=trace || "$arg_lower" == --log-level=all ]] && DEBUG_MODE=1 && break
done

PULL_FLAG=""
if [ "${SPICE_LABS_CLI_SKIP_PULL:-0}" = "1" ]; then
  PULL_FLAG="--pull=never"
elif [ "$DEBUG_MODE" = "1" ]; then
  echo "📦 Checking for updates to Spice Labs Surveyor CLI..."
  docker pull "$IMAGE_REF" || {
    echo "⚠️  Failed to pull $IMAGE_REF"
    docker image inspect "$IMAGE_REF" >/dev/null 2>&1 || {
      echo "❌ Image $IMAGE_REF not found locally either."
      echo "   The image may not exist yet, or you may not have access."
      echo "   For enterprise/federal features, ensure --features matches an available image."
      exit 1
    }
    echo "   Using local copy."
  }
else
  echo "📦 Checking for updates to Spice Labs Surveyor CLI..."
  docker pull --quiet "$IMAGE_REF" >/dev/null 2>&1 || {
    echo "⚠️  Failed to pull $IMAGE_REF"
    docker image inspect "$IMAGE_REF" >/dev/null 2>&1 || {
      echo "❌ Image $IMAGE_REF not found locally either."
      echo "   The image may not exist yet, or you may not have access."
      echo "   For enterprise/federal features, ensure --features matches an available image."
      exit 1
    }
    echo "   Using local copy."
  }
fi

for arg in "$@"; do
  [[ "$arg" == "-V" || "$arg" == "--version" ]] && echo "script version ${LOCAL_HASH}" && break
done

# ── Runtime survey detection (must happen before general arg parsing) ───────
# survey runtime args contain "-- <command...>" which the general parser
# would misinterpret as positional path args. Detect and handle early.

IS_RUNTIME_SURVEY=0
{
  saw_survey=0
  for arg in "$@"; do
    if [ "$saw_survey" = "1" ] && [ "$arg" = "runtime" ]; then
      IS_RUNTIME_SURVEY=1
      break
    fi
    [ "$arg" = "survey" ] && saw_survey=1 || saw_survey=0
  done
}

if [ "$IS_RUNTIME_SURVEY" = "1" ]; then
  # Parse runtime survey args ourselves — split at "--" into CLI flags + user command.
  RT_CLI_ARGS=()
  RT_USER_CMD=()
  RT_SUBJECT=""
  RT_OUTPUT_PATH=""
  RT_ANCHOR=""
  RT_NO_UPLOAD=0
  RT_NATIVE_ONLY=0
  RT_KEEP_RECORDING=0
  rt_past_sep=0
  rt_prev=""
  rt_pos=0

  for arg in "$@"; do
    # Strip --log-file (handled at shell level)
    if [[ "$arg" == --log-file=* ]]; then
      continue
    elif [[ "$rt_prev" == "--log-file" ]]; then
      rt_prev=""
      continue
    elif [[ "$arg" == "--log-file" ]]; then
      rt_prev="$arg"
      continue
    fi

    if [[ "$arg" == "--" ]] && [ "$rt_past_sep" = "0" ]; then
      rt_past_sep=1
      continue
    fi
    if [ "$rt_past_sep" = "1" ]; then
      RT_USER_CMD+=("$arg")
      continue
    fi

    # Capture --output value
    if [[ "$arg" == --output=* ]]; then
      RT_OUTPUT_PATH="${arg#--output=}"
      continue
    elif [[ "$rt_prev" == "--output" ]]; then
      RT_OUTPUT_PATH="$arg"
      rt_prev=""
      continue
    elif [[ "$arg" == "--output" ]]; then
      rt_prev="$arg"
      continue
    fi

    # Capture --anchor value (the host jar this survey is of; mounted into the
    # collect container below so its gitoid can be hashed for CBOM correlation)
    if [[ "$arg" == --anchor=* ]]; then
      RT_ANCHOR="${arg#--anchor=}"
      continue
    elif [[ "$rt_prev" == "--anchor" ]]; then
      RT_ANCHOR="$arg"
      rt_prev=""
      continue
    elif [[ "$arg" == "--anchor" ]]; then
      rt_prev="$arg"
      continue
    fi

    # Handle value-consuming flags
    if [ -n "$rt_prev" ]; then
      RT_CLI_ARGS+=("$rt_prev" "$arg")
      rt_prev=""
      continue
    fi

    if [[ "$arg" == -* ]]; then
      [[ "$arg" == "--no-upload" ]] && RT_NO_UPLOAD=1
      [[ "$arg" == "--native-only" ]] && RT_NATIVE_ONLY=1
      [[ "$arg" == "--keep-recording" ]] && RT_KEEP_RECORDING=1
      if is_value_flag "$arg"; then
        rt_prev="$arg"
      else
        RT_CLI_ARGS+=("$arg")
      fi
      continue
    fi

    # Positional: subcommands pass through, first non-subcommand is subject
    if is_subcommand "$arg"; then
      RT_CLI_ARGS+=("$arg")
    else
      rt_pos=$((rt_pos + 1))
      if [ $rt_pos -eq 1 ]; then
        RT_SUBJECT="$arg"
        RT_CLI_ARGS+=("$arg")
      else
        RT_CLI_ARGS+=("$arg")
      fi
    fi
  done
  [ -n "$rt_prev" ] && RT_CLI_ARGS+=("$rt_prev")

  if [ ${#RT_USER_CMD[@]} -eq 0 ]; then
    echo "❌ No command specified after --"
    echo "Usage: spice survey runtime <subject> --jfr -- <command...>"
    exit 1
  fi

  if [ -z "$RT_SUBJECT" ]; then
    echo "❌ No subject specified"
    echo "Usage: spice survey runtime <subject> --jfr -- <command...>"
    exit 1
  fi

  # Create workdir under the output dir (or default location)
  RT_BASE="${RT_OUTPUT_PATH:-$HOME/.spicelabs/runtime-survey}"
  mkdir -p "$RT_BASE"
  RT_WORKDIR=$(mktemp -d "$RT_BASE/survey-XXXXXXXX")

  # Phase 1: Copy agent + JFC from container to host workdir
  echo "🌶️  Preparing runtime survey..."
  SPICE_CLI_DIR=$(dirname "${SPICE_LABS_CLI_JAR}")
  docker run --rm --entrypoint sh \
    --user "$(id -u):$(id -g)" \
    ${PULL_FLAG:+$PULL_FLAG} \
    -v "${RT_WORKDIR}:${RT_WORKDIR}" \
    "$IMAGE_REF" \
    -c "cp '${SPICE_CLI_DIR}/ancho.jar' '${RT_WORKDIR}/' 2>/dev/null; \
        cp '${SPICE_CLI_DIR}/spice-jfr.jfc' '${RT_WORKDIR}/' 2>/dev/null"

  # Phase 2: Build JAVA_TOOL_OPTIONS
  RT_JFC="${RT_WORKDIR}/spice-jfr.jfc"
  if [ ! -f "$RT_JFC" ]; then
    echo "❌ Failed to extract JFR settings from container"
    rm -rf "$RT_WORKDIR"
    exit 1
  fi

  SPICE_JTO="-XX:StartFlightRecording=settings=${RT_JFC},dumponexit=true,filename=${RT_WORKDIR}/recording-%p.jfr"

  if [ "$RT_NATIVE_ONLY" = "0" ] && [ -f "$RT_WORKDIR/ancho.jar" ]; then
    # Download probe config from server via container, piped to host
    echo "📡 Downloading probe configuration..."
    RT_PROBES="${RT_WORKDIR}/probes.json"
    docker run --rm --entrypoint java \
      --user "$(id -u):$(id -g)" \
      --network host \
      ${PULL_FLAG:+$PULL_FLAG} \
      -e SPICE_PASS \
      "$IMAGE_REF" \
      -cp "${SPICE_LABS_CLI_JAR}" \
      io.spicelabs.cli.RuntimeCollect \
      --download-probes >"$RT_PROBES" 2>/dev/null || true

    if [ -s "$RT_PROBES" ]; then
      SPICE_JTO="-javaagent:${RT_WORKDIR}/ancho.jar=${RT_PROBES} ${SPICE_JTO}"
    else
      rm -f "$RT_PROBES"
      echo "⚠️  Could not download probe config. Using native-only mode."
    fi
  fi

  # Phase 3: Execute target command on the HOST
  echo "🚀 Executing: ${RT_USER_CMD[*]}"
  EXISTING_JTO="${JAVA_TOOL_OPTIONS:-}"
  if [ -n "$EXISTING_JTO" ]; then
    export JAVA_TOOL_OPTIONS="${SPICE_JTO} ${EXISTING_JTO}"
  else
    export JAVA_TOOL_OPTIONS="${SPICE_JTO}"
  fi

  set +e
  "${RT_USER_CMD[@]}"
  RT_TARGET_RC=$?
  set -e

  # Restore original JAVA_TOOL_OPTIONS
  if [ -n "$EXISTING_JTO" ]; then
    export JAVA_TOOL_OPTIONS="$EXISTING_JTO"
  else
    unset JAVA_TOOL_OPTIONS
  fi

  if [ $RT_TARGET_RC -ne 0 ]; then
    echo "⚠️  Target command exited with code $RT_TARGET_RC. Still collecting recordings."
  fi

  # Check for recordings
  RT_JFR_COUNT=$(find "$RT_WORKDIR" -maxdepth 1 -name '*.jfr' 2>/dev/null | wc -l)
  if [ "$RT_JFR_COUNT" -eq 0 ]; then
    echo "❌ No JFR recordings found in $RT_WORKDIR"
    [ "$RT_KEEP_RECORDING" = "0" ] && rm -rf "$RT_WORKDIR"
    exit 1
  fi

  # Phase 4: Parse + upload in container
  echo "📊 Analyzing recordings..."
  RT_COLLECT_ARGS=("$RT_SUBJECT" "$RT_WORKDIR")
  [ "$RT_NO_UPLOAD" = "1" ] && RT_COLLECT_ARGS+=("--no-upload")

  RT_ANCHOR_MOUNT=()
  if [ -n "$RT_ANCHOR" ]; then
    RT_ANCHOR_ABS="$(abs_path "$RT_ANCHOR")"
    RT_ANCHOR_MOUNT=("-v" "${RT_ANCHOR_ABS}:${RT_ANCHOR_ABS}:ro")
    RT_COLLECT_ARGS+=("--anchor" "${RT_ANCHOR_ABS}")
  fi

  docker run --rm --entrypoint java \
    --user "$(id -u):$(id -g)" \
    --network host \
    ${PULL_FLAG:+$PULL_FLAG} \
    -v "${RT_WORKDIR}:${RT_WORKDIR}" \
    ${RT_ANCHOR_MOUNT[@]+"${RT_ANCHOR_MOUNT[@]}"} \
    -e SPICE_PASS \
    "$IMAGE_REF" \
    -cp /opt/spice-labs-cli/spice-labs-cli.jar \
    io.spicelabs.cli.RuntimeCollect \
    "${RT_COLLECT_ARGS[@]}"
  RT_COLLECT_RC=$?

  # Clean up
  if [ "$RT_KEEP_RECORDING" = "0" ]; then
    rm -rf "$RT_WORKDIR"
  else
    echo "Recordings kept in: $RT_WORKDIR"
  fi

  exit $((RT_TARGET_RC != 0 ? RT_TARGET_RC : RT_COLLECT_RC))
fi

# ── Registry (allspice) detection ─────────────────────────────────────────────
# `registry` has its own grammar: --config/--discovery/--output are file paths and there
# are no subject/input positionals. Mount each path flag's directory at the SAME path in
# the container (so args need no remapping beyond becoming absolute), which also lets the
# git-backed state dir — created next to the config — persist on the host.

IS_REGISTRY=0
for arg in "$@"; do
  [[ "$arg" == -* ]] && continue # skip leading global flags
  [ "$arg" = "registry" ] && IS_REGISTRY=1
  break # first positional decides
done

if [ "$IS_REGISTRY" = "1" ]; then
  REG_ARGS=()
  REG_VOLUMES=()
  REG_SEEN_DIRS=""
  reg_prev=""

  reg_dir_of() { # echo the directory to mount for a path (file may not yet exist)
    local p="$1"
    if [ -d "$p" ]; then
      (cd "$p" && pwd)
    else
      local parent
      parent="$(dirname "$p" 2>/dev/null)"
      [ -n "$parent" ] || parent="."
      (cd "$parent" 2>/dev/null && pwd) || {
        echo "ERROR ❌ Directory does not exist for path: $p" >&2
        exit 2
      }
    fi
  }
  reg_abs_of() { # echo the absolute path (file may not yet exist)
    local p="$1"
    if [ -d "$p" ]; then
      (cd "$p" && pwd)
    else echo "$(cd "$(dirname "$p")" && pwd)/$(basename "$p")"; fi
  }
  reg_mount() { # add a same-path volume for the given path's dir (deduped)
    local dir
    dir="$(reg_dir_of "$1")"
    case ":$REG_SEEN_DIRS:" in *":$dir:"*) ;; *)
      REG_SEEN_DIRS="$REG_SEEN_DIRS:$dir"
      REG_VOLUMES+=("-v" "${dir}:${dir}")
      ;;
    esac
  }

  for arg in "$@"; do
    # Strip --log-file (handled at shell level)
    if [[ "$arg" == --log-file=* ]]; then
      continue
    elif [[ "$reg_prev" == "--log-file" ]]; then
      reg_prev=""
      continue
    elif [[ "$arg" == "--log-file" ]]; then
      reg_prev="$arg"
      continue
    fi

    # Path flags (=joined form)
    case "$arg" in
    --config=* | --discovery=* | --output=* | --dir=* | --file=*)
      flag="${arg%%=*}"
      val="${arg#*=}"
      reg_mount "$val"
      REG_ARGS+=("${flag}=$(reg_abs_of "$val")")
      continue
      ;;
    --config | --discovery | --output | --dir | --file)
      reg_prev="$arg"
      continue
      ;;
    esac

    # Path flags (space-separated value)
    if [[ "$reg_prev" == "--config" || "$reg_prev" == "--discovery" || "$reg_prev" == "--output" || "$reg_prev" == "--dir" || "$reg_prev" == "--file" ]]; then
      reg_mount "$arg"
      REG_ARGS+=("$reg_prev" "$(reg_abs_of "$arg")")
      reg_prev=""
      continue
    fi

    REG_ARGS+=("$arg")
  done
  [ -n "$reg_prev" ] && REG_ARGS+=("$reg_prev")

  exec docker run --rm \
    --user "$(id -u):$(id -g)" \
    --network host \
    ${PULL_FLAG:+$PULL_FLAG} \
    ${SPICE_DOCKER_FLAGS:+$SPICE_DOCKER_FLAGS} \
    ${REG_VOLUMES[@]+"${REG_VOLUMES[@]}"} \
    -e SPICE_PASS \
    -e SPICE_PATH_MAP \
    ${SPICE_LABS_JVM_ARGS:+-e SPICE_LABS_JVM_ARGS} \
    "$IMAGE_REF" \
    ${REG_ARGS[@]+"${REG_ARGS[@]}"}
fi

